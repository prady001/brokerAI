# ==============================================================================
# brokerAI — Environment Variables
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais — ele está no .gitignore.
# ==============================================================================

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- WhatsApp (Twilio) ---
# Account SID (console.twilio.com → Account Info)
TWILIO_ACCOUNT_SID=
# Auth Token (console.twilio.com → Account Info)
TWILIO_AUTH_TOKEN=
# Número de origem — sandbox: whatsapp:+14155238886 | produção: whatsapp:+55...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/insurance_agents
POSTGRES_DB=insurance_agents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Storage (Cloudflare R2 — compatível com S3) ---
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=brokerai-documents
# Endpoint gerado automaticamente: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT=

# --- Notificações (telefone e e-mail do corretor) ---
BROKER_NOTIFICATION_PHONE=5517999999999  # DDI + DDD + número (sem espaços)
BROKER_NOTIFICATION_EMAIL=corretor@corretora.com.br

# --- Agente de Renovação (CRON) ---
RENEWAL_CRON_HOUR=8
RENEWAL_CRON_TIMEZONE=America/Sao_Paulo
RENEWAL_ALERT_DAYS=30,15,7,0   # dias antes do vencimento para contato
RENEWAL_MAX_CONTACTS=4
RENEWAL_OVERDUE_DAYS=3

# --- Observability ---
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
SENTRY_DSN=

# --- Ambiente ---
ENVIRONMENT=development  # development | staging | production

# ==============================================================================
# V1+ — Integrações de portais de seguradoras (RPA + API + 2FA)
# Não utilizadas no MVP.
# ==============================================================================

# Focus NFe API (emissão de NFS-e — V1)
# FOCUS_NFE_API_KEY=
# FOCUS_NFE_BASE_URL=https://homologacao.focusnfe.com.br
# BROKER_CNPJ=
# BROKER_CITY_CODE=

# Gateway SMS para 2FA de portais (V1)
# SMS_GATEWAY_PROVIDER=  # twilio | zenvia | infobip
# SMS_GATEWAY_API_KEY=
# SMS_GATEWAY_FROM_NUMBER=

# IMAP para 2FA por e-mail (V1)
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=
# IMAP_PASSWORD=

# Credenciais criptografadas dos portais das seguradoras (V1)
# INSURER_CREDENTIALS_PATH=./config/insurers.json.enc
# INSURER_CREDENTIALS_KEY=

# ==============================================================================
# V1+ — Graph Memory (Graphiti + Neo4j)
# ==============================================================================

# GRAPH_MEMORY_ENABLED=false
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
# GRAPHITI_API_KEY=
# LANGMEM_ENABLED=false
