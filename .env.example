# ==============================================================================
# brokerAI — Environment Variables Example
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais — ele está no .gitignore.
# ==============================================================================

# --- LLM & AI Services ---
ANTHROPIC_API_KEY=sk-ant-...

# --- WhatsApp (Z-API) ---
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_WEBHOOK_SECRET=  # segredo HMAC para validar assinatura do webhook

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/insurance_agents
POSTGRES_DB=insurance_agents
POSTGRES_USER=user
POSTGRES_PASSWORD=

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=brokerai-documents

# --- NFS-e (Focus NFe) ---
FOCUS_NFE_API_KEY=
FOCUS_NFE_BASE_URL=https://homologacao.focusnfe.com.br  # prod: https://producao.focusnfe.com.br
BROKER_CNPJ=  # CNPJ da corretora (somente números)
BROKER_CITY_CODE=  # código IBGE do município do CNPJ

# --- 2FA / SMS Gateway ---
SMS_GATEWAY_PROVIDER=  # twilio | zenvia | infobip
SMS_GATEWAY_API_KEY=
SMS_GATEWAY_FROM_NUMBER=

# --- 2FA / Email IMAP (para portais que enviam OTP por e-mail) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# --- Insurer Portal Credentials ---
# Credenciais das seguradoras ficam em arquivo JSON criptografado (AES-256).
# Veja config/insurers.example.json para o formato esperado.
INSURER_CREDENTIALS_PATH=./config/insurers.json.enc
INSURER_CREDENTIALS_KEY=  # chave AES-256 em hex (64 chars)

# --- Notifications ---
SENDGRID_API_KEY=
BROKER_NOTIFICATION_PHONE=5511999999999  # DDI + DDD + número
BROKER_NOTIFICATION_EMAIL=corretor@corretora.com.br

# --- Commission Schedule ---
COMMISSION_CRON_HOUR=8
COMMISSION_CRON_TIMEZONE=America/Sao_Paulo

# --- Observability ---
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
SENTRY_DSN=

# --- Environment ---
ENVIRONMENT=development  # development | staging | production

# ==============================================================================
# V1+ — Graph Memory (Graphiti + Neo4j)
# Não utilizadas no MVP. Descomentar ao iniciar desenvolvimento da V1 (mês 6).
# Descomentar também o serviço neo4j no docker-compose.yml.
# ==============================================================================

# GRAPH_MEMORY_ENABLED=false
# GRAPHITI_API_KEY=
# GRAPHITI_API_URL=http://localhost:8001
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
# LANGMEM_ENABLED=false
