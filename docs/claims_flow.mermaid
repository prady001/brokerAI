flowchart TD
    CLIENT["📱 Cliente envia mensagem\nno WhatsApp da corretora"]

    ORCH["🧠 Orquestrador\ndetecta intent = sinistro"]

    COLLECT["collect_claim_info\ncoleta tipo, localização\ne dados da apólice/placa"]

    CLASSIFY["classify_claim\nclassifica severidade"]

    SIMPLE{{"Sinistro simples?\n(guincho, assistência,\nvidro)"}}

    GRAVE["⚠️ Sinistro grave\n(colisão, furto,\nacidente c/ vítima)"]

    OPEN["open_claim_at_insurer\nabre chamado na seguradora\nvia API ou WhatsApp"]

    ESCALATE["escalate_to_broker\nnotifica corretor com\nresumo estruturado"]

    CLIENT_NOTIFY_GRAVE["relay_update_to_client\ninforma que corretor\nentrará em contato"]

    HUMAN["👤 Corretor Humano\nconduz caso grave"]

    WAIT["Aguarda resposta\nda seguradora\n(estado em Redis)"]

    UPDATE["relay_update_to_client\nrepassa atualização\nao cliente"]

    RESOLVED{{"Caso encerrado?"}}

    STORE["store_claim_history\nregistra histórico\ncompleto no PostgreSQL"]

    END["✅ Sinistro encerrado"]

    CLIENT --> ORCH --> COLLECT --> CLASSIFY --> SIMPLE

    SIMPLE -->|"não"| GRAVE
    GRAVE --> ESCALATE --> CLIENT_NOTIFY_GRAVE --> HUMAN
    HUMAN -->|"atende o cliente diretamente"| END

    SIMPLE -->|"sim"| OPEN --> WAIT --> UPDATE --> RESOLVED
    RESOLVED -->|"não"| WAIT
    RESOLVED -->|"sim"| STORE --> END

    style CLIENT fill:#4A90D9,color:#fff
    style ORCH fill:#4A90D9,color:#fff
    style GRAVE fill:#E74C3C,color:#fff
    style ESCALATE fill:#E74C3C,color:#fff
    style HUMAN fill:#F39C12,color:#fff
    style END fill:#2ECC71,color:#fff
    style STORE fill:#27AE60,color:#fff
