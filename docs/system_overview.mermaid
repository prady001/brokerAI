graph TD
    CRON["⏰ CRON Scheduler\ndiário 08:00 BRT"]
    WA["📱 WhatsApp Business API\n(cliente)"]

    GW["🔀 API Gateway\nFastAPI"]

    COMM["💰 Agente de Comissionamento\nacessa portais · consolida · emite NFS-e"]
    ORCH["🧠 Agente Orquestrador\ndetecta intenção · roteia · handoff"]
    CLAIMS["🚨 Agente de Sinistros\nrelay cliente ↔ seguradora"]
    HUMAN["👤 Corretor Humano\nexceções e casos graves"]

    IPS["InsurerPortalService\nAPI adapter · RPA adapter · 2FA"]
    CS["CommissionService"]
    NFSE["NfseService\nFocus NFe API"]
    CLS["ClaimService"]
    NS["NotificationService\nZ-API · SendGrid"]

    PG[("PostgreSQL\ndados primários")]
    RD[("Redis\nestado de conversas")]
    S3[("AWS S3\ndocumentos")]
    INSURER["🏢 Portais das Seguradoras\nAPI REST ou RPA"]
    FOCUSNFE["🧾 Focus NFe\nNFS-e API"]

    CRON --> GW
    WA --> GW
    GW -->|"POST /scheduler/commission-check"| COMM
    GW -->|"POST /webhook/whatsapp"| ORCH

    COMM --> IPS
    COMM --> CS
    COMM --> NFSE
    COMM --> NS

    ORCH -->|"intent = sinistro"| CLAIMS
    ORCH -->|"intent = unknown"| HUMAN

    CLAIMS --> CLS
    CLAIMS --> NS
    CLAIMS -->|"sinistro grave"| HUMAN

    IPS --> INSURER
    NFSE --> FOCUSNFE
    NS --> WA

    CS --> PG
    CLS --> PG
    ORCH --> RD
    CLAIMS --> RD
    CLS --> S3

    style COMM fill:#2ECC71,color:#fff
    style CLAIMS fill:#E74C3C,color:#fff
    style ORCH fill:#4A90D9,color:#fff
