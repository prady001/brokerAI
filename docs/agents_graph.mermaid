flowchart TD
    CRON["⏰ CRON 08:00 BRT"]
    WA["📱 WhatsApp\nCliente"]
    GW["🔀 API Gateway"]

    COMM["💰 Agente de Comissionamento
    ─────────────────────
    Tools:
    · fetch_commission_data
    · handle_2fa
    · consolidate_report
    · emit_nfse
    · send_daily_summary
    · alert_missing_commission"]

    ORCH["🧠 Agente Orquestrador
    ─────────────────
    • Detecta intenção
    • Gerencia estado
    • Controla handoffs"]

    CLAIMS["🚨 Agente de Sinistros
    ─────────────────────
    Tools:
    · classify_claim
    · collect_claim_info
    · open_claim_at_insurer
    · relay_update_to_client
    · escalate_to_broker
    · store_claim_history"]

    HUMAN["👤 Corretor Humano
    ─────────────────
    Recebe handoff
    age manualmente"]

    REDIS[("Redis\nestado")]
    PG[("PostgreSQL\ndados")]

    CRON --> GW -->|"commission-check"| COMM
    WA -->|"mensagem"| GW -->|"webhook"| ORCH

    ORCH -->|"intent = sinistro"| CLAIMS
    ORCH -->|"intent = unknown"| HUMAN

    CLAIMS -->|"sinistro grave / pedido humano"| HUMAN
    COMM -->|"resumo diário"| WA

    CLAIMS <-->|"lê e salva estado"| REDIS
    ORCH <-->|"lê e salva estado"| REDIS

    COMM -->|"persiste comissões"| PG
    CLAIMS -->|"persiste sinistros"| PG

    HUMAN -->|"responde ao cliente"| WA

    style COMM fill:#2ECC71,color:#fff
    style CLAIMS fill:#E74C3C,color:#fff
    style ORCH fill:#4A90D9,color:#fff
    style HUMAN fill:#F39C12,color:#fff
